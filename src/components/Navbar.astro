---
const whatsappNumber = "34699489038"; 

const whatsappLink = `https://wa.me/${whatsappNumber}?text=Hola%2C%20quiero%20informaci%C3%B3n%20sobre%20la%20importaci%C3%B3n%20de%20un%20coche%20desde%20Alemania.`;

const links = [
  { href: "#proceso", label: "Proceso" },
  { href: whatsappLink, label: "WhatsApp", external: true },
];
---
<header style="position:sticky; top:0; z-index:50; backdrop-filter: blur(14px); background: rgba(7,8,11,.55); border-bottom:1px solid rgba(255,255,255,.06);">
  <div class="container headerBar">
    <div class="brandWrap">
      <span class="pill logoPill">
        <img
          src="/images/logo-lemoncars.jpg"
          alt="LEMONCARS"
          class="logoImg"
        />
      </span>
      <span class="tagline">Importación premium</span>
    </div>

    <nav class="nav">
      {links.map(l => (
        <a
          href={l.href}
          target={l.external ? "_blank" : undefined}
          rel={l.external ? "noopener" : undefined}
          style="color:var(--muted); padding:.55rem .7rem; border-radius:999px; border:1px solid transparent;"
          class={l.label === "WhatsApp" ? "whatsLink" : ""}
        >
          {l.label === "WhatsApp" ? (
            <>
              <span class="whatsIcon" aria-hidden="true">
                <svg viewBox="0 0 32 32" fill="none">
                  <path
                    d="M16 3C9.1 3 3.5 8.6 3.5 15.5c0 2.4.7 4.6 1.9 6.5L4 29l7.2-1.9c1.8 1 3.9 1.6 6.1 1.6 6.9 0 12.5-5.6 12.5-12.5S22.9 3 16 3Z"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linejoin="round"
                  />
                  <path
                    d="M12.7 12.4c.2-.4.4-.5.7-.5h.7c.2 0 .4.1.5.4l.8 2c.1.3.1.5-.1.7l-.6.7c-.1.2-.1.4 0 .6.5.9 1.5 1.9 2.6 2.6.2.1.4.1.6 0l.8-.6c.2-.2.4-.2.7-.1l2 .8c.3.1.4.3.4.5v.7c0 .3-.2.6-.5.7-.6.4-1.5.5-2.4.3-1.6-.5-3.4-1.7-5-3.3-1.6-1.6-2.8-3.4-3.3-5-.2-.9-.1-1.8.3-2.4Z"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
              <span>WhatsApp</span>
            </>
          ) : (
            l.label
          )}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
header{
  position: sticky;
  top: 0;
  z-index: 9999;
}

.headerBar{
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:10px;
  padding:14px 0;
}

.brandWrap{
  display:flex;
  align-items:center;
  gap:.7rem;
  min-width:0;
}

.tagline{
  color:var(--muted);
  font-size:.8rem;
  white-space:nowrap;
}


.nav{
  display:flex;
  gap:8px;
  align-items:center;
  flex-wrap:nowrap;
}

.nav a{
  font-size:.85rem;
  white-space:nowrap;
}

/* Desktop */
@media (min-width: 860px){
  .nav{ gap:14px; }
  .nav a{ font-size:1rem; }
  .tagline{ font-size:.9rem; }
}

/* Ocultar en móvil */
@media (max-width: 859px){
  .tagline{
    display: none !important;
  }
}

/* Móvil */
@media (max-width: 859px){
  .logoImg{
    max-height:42px;
    width:auto;
  }

  .tagline{
    font-size:.72rem;
  }

  .nav a{
    padding:.4rem .45rem !important;
    font-size:.78rem;
  }

  .whatsIcon{
    width:16px;
    height:16px;
  }

  .whatsIcon svg{
    width:16px;
    height:16px;
  }
}

/* Hover general */
nav a:hover{
  color: var(--text);
  border-color: rgba(255,255,255,.10);
  background: rgba(255,255,255,.03);
}

.whatsLink{
  display:flex;
  align-items:center;
  gap:8px;
  transition: all .2s ease;
}

.whatsIcon{
  display:inline-flex;
  width: 18px;
  height: 18px;
  color: #25D366;
  transition: transform .2s ease;
}

.whatsIcon svg{
  width: 18px;
  height: 18px;
  display:block;
}

.whatsLink:hover{
  color: #25D366;
  border-color: rgba(37,211,102,.25);
  background: rgba(37,211,102,.08);
}

.whatsLink:hover .whatsIcon{
  transform: scale(1.1);
}
</style>