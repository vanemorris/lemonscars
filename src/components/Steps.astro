---
const steps = [
  { n: "01", t: "Brief & presupuesto", d: "Objetivo, país, modelo, extras y rango. Te damos precio cerrado estimado." },
  { n: "02", t: "Búsqueda y negociación", d: "Localizamos unidades entre los millones de anunción con modelos de Inteliegencia artificial. , negociamos y bloqueamos la mejor opción." },
  { n: "03", t: "Inspección e informe", d: "Revisión mecánica/estética + historial. Solo avanzamos si está perfecto." },
  { n: "04", t: "Transporte y aduanas", d: "Logística asegurada, documentación, impuestos, aranceles y gestión." },
  { n: "05", t: "Homologación y matriculación", d: "Tramitación para que lo disfrutes legalmente en tu país." },
];
---
<section class="section" id="proceso">
  <div class="container">
    <div style="display:flex; justify-content:space-between; gap:16px; align-items:flex-end; flex-wrap:wrap;">
      <div>
        <h2 class="h2">Un proceso premium, sin estrés</h2>
        <p class="p" style="max-width: 65ch;">Transparente, documentado y con seguimiento. Tú eliges el coche, nosotros hacemos el resto.</p>
      </div>
      <!--a class="btn" href="#contacto">Hablar con un asesor</a-->
    </div>

    <div class="grid cols3" style="margin-top: 18px;">
      {steps.map(s => (
        <article class="card" style="padding:18px; position:relative; overflow:hidden;">
          <div style="position:absolute; inset:-2px; background: radial-gradient(420px 180px at 20% 0%, rgba(199,164,74,.18), transparent 60%); pointer-events:none;"></div>
          <div class="pill" style="display:inline-flex; border-color: rgba(255,255,255,.10); color: var(--text);">
            <span style="color: var(--accent); font-weight:900;">{s.n}</span>
            <span>Paso</span>
          </div>
          <h3 style="margin:12px 0 8px; font-size:1.15rem; letter-spacing:-0.02em;">{s.t}</h3>
          <p class="p">{s.d}</p>
        </article>
      ))}
    </div>
  </div>
</section>
